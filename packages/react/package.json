{
  "name": "@realflow/react",
  "version": "0.2.1",
  "description": "The fastest, most beautiful React library for building node-based UIs. Fine-grained rendering, built-in auto-layout, undo/redo, alignment guides \u2014 free and open source.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/append-js-extensions.mjs dist && cp src/styles.css dist/styles.css"
  },
  "dependencies": {
    "@realflow/core": "0.2.1"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "keywords": [
    "react",
    "node-based-ui",
    "react-flow-alternative",
    "graph",
    "flow",
    "diagram",
    "workflow",
    "dag"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olbboy/realflow.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/olbboy/realflow#readme",
  "bugs": "https://github.com/olbboy/realflow/issues"
}
