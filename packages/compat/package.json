{
  "name": "@realflow/compat",
  "version": "0.2.1",
  "description": "Drop-in React Flow (xyflow) API compatibility layer for RealFlow. Migrate an existing React Flow app by changing one import.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/append-js-extensions.mjs dist && cp ../react/src/styles.css dist/style.css"
  },
  "dependencies": {
    "@realflow/core": "0.2.1",
    "@realflow/react": "0.2.1"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "keywords": [
    "react-flow",
    "xyflow",
    "migration",
    "compat",
    "node-based-ui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olbboy/realflow.git",
    "directory": "packages/compat"
  },
  "homepage": "https://github.com/olbboy/realflow#readme",
  "bugs": "https://github.com/olbboy/realflow/issues"
}
