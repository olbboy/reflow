{
  "name": "@reflow/core",
  "version": "0.1.0",
  "description": "Headless, zero-dependency engine for node-based UIs: reactive graph store, spatial indexing, auto-layout, undo/redo, interactions.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/append-js-extensions.mjs dist"
  },
  "keywords": [
    "node-based-ui",
    "graph",
    "flow",
    "diagram",
    "headless",
    "workflow"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olbboy/reflow.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/olbboy/reflow#readme",
  "bugs": "https://github.com/olbboy/reflow/issues"
}
