{
  "name": "realflow-monorepo",
  "private": true,
  "version": "0.2.1",
  "description": "RealFlow — the fastest, most beautiful open source library for building node-based UIs with React",
  "workspaces": [
    "packages/*",
    "examples/*",
    "benchmarks"
  ],
  "scripts": {
    "build": "npm run build -w @realflow/core -w @realflow/react",
    "build:demo": "npm run build -w realflow-demo",
    "dev": "npm run dev -w realflow-demo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p packages/core/tsconfig.build.json --noEmit && tsc -p packages/react/tsconfig.build.json --noEmit && tsc -p packages/compat/tsconfig.build.json --noEmit",
    "bench": "npm run bench -w realflow-benchmarks",
    "dev:docs": "npm run dev -w realflow-docs-site",
    "build:docs": "npm run build -w realflow-docs-site",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:e2e": "playwright test --project=chromium --project=firefox --project=webkit --project=mobile-webkit",
    "test:e2e:visual": "playwright test --project=visual",
    "test:e2e:install": "playwright install"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@xyflow/react": "^12.11.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.7.0",
    "jsdom": "^25.0.0",
    "playwright": "^1.61.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^2.1.8",
    "yjs": "^13.6.31"
  },
  "engines": {
    "node": ">=18"
  }
}
