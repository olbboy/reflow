{
  "name": "reflow-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "ReFlow \u2014 the fastest, most beautiful open source library for building node-based UIs with React",
  "workspaces": [
    "packages/*",
    "examples/*",
    "benchmarks"
  ],
  "scripts": {
    "build": "npm run build -w @reflow/core -w @reflow/react",
    "build:demo": "npm run build -w reflow-demo",
    "dev": "npm run dev -w reflow-demo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p packages/core/tsconfig.build.json --noEmit && tsc -p packages/react/tsconfig.build.json --noEmit && tsc -p packages/compat/tsconfig.build.json --noEmit",
    "bench": "npm run bench -w reflow-benchmarks",
    "dev:docs": "npm run dev -w reflow-docs-site",
    "build:docs": "npm run build -w reflow-docs-site"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@xyflow/react": "^12.11.2",
    "jsdom": "^25.0.0",
    "playwright": "^1.61.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.8",
    "yjs": "^13.6.31"
  },
  "engines": {
    "node": ">=18"
  }
}
